# MBSI Studio — environment configuration
# Copy to `.env` (git-ignored) and adjust per environment (dev / staging / prod).
# All variables are optional; defaults are shown and are safe for local development.

# ---- Runtime mode -----------------------------------------------------------
# Enable the developer/diagnostics UI in the Streamlit app ("1"/"true"/"yes"/"on").
DEVELOPER_MODE=

# Route the Streamlit entrypoint to the dashboard view ("1"/"true"/"yes").
MBSI_DASHBOARD=

# ---- API server -------------------------------------------------------------
# Comma-separated list of allowed CORS origins. Use an explicit allowlist in
# production; the default "*" is for local development ONLY.
# Example (prod): https://app.example.com,https://studio.example.com
MBSI_CORS_ALLOW_ORIGINS=*

# Bind host/port for the uvicorn API (compose already sets these on the command).
MBSI_API_HOST=0.0.0.0
MBSI_API_PORT=8000

# Number of uvicorn worker processes in production (see docker-compose.prod.yml).
WEB_CONCURRENCY=4

# ---- Data paths (inside the container) --------------------------------------
MBSI_DATA_DIR=/app/data

# ---- Frontend (AIStudio) ----------------------------------------------------
# Consumed by the React build, not the Python service. Kept here for reference.
# VITE_API_BASE_URL=http://localhost:8000
